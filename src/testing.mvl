// pkg.http.testing — response parsing and BDD-style assertion helpers.
//
// Pure MVL.  No runtime dependencies — works today with stdlib-only.
//
// Usage:
//   use pkg.http.{test_request, parse_response, expect_status,
//                 expect_body_contains, expect_header}
//
// See #951.
// ── HttpStatus reconstruction ────────────────────────────────────────────────────
/// Map a numeric status code back to a HttpStatus enum.  Unknown codes are
/// rejected with a 400-class error.
total fn status_from_code(code: Int) -> Result[HttpStatus, HttpError] {
    if code == 200 {
        Ok(HttpStatus::Http200Ok)
    } else if code == 201 {
        Ok(HttpStatus::Http201Created)
    } else if code == 202 {
        Ok(HttpStatus::Http202Accepted)
    } else if code == 204 {
        Ok(HttpStatus::Http204NoContent)
    } else if code == 301 {
        Ok(HttpStatus::Http301MovedPermanently)
    } else if code == 302 {
        Ok(HttpStatus::Http302Found)
    } else if code == 304 {
        Ok(HttpStatus::Http304NotModified)
    } else if code == 400 {
        Ok(HttpStatus::Http400BadRequest)
    } else if code == 401 {
        Ok(HttpStatus::Http401Unauthorized)
    } else if code == 403 {
        Ok(HttpStatus::Http403Forbidden)
    } else if code == 404 {
        Ok(HttpStatus::Http404NotFound)
    } else if code == 405 {
        Ok(HttpStatus::Http405MethodNotAllowed)
    } else if code == 409 {
        Ok(HttpStatus::Http409Conflict)
    } else if code == 410 {
        Ok(HttpStatus::Http410Gone)
    } else if code == 422 {
        Ok(HttpStatus::Http422UnprocessableEntity)
    } else if code == 429 {
        Ok(HttpStatus::Http429TooManyRequests)
    } else if code == 500 {
        Ok(HttpStatus::Http500InternalServerError)
    } else if code == 501 {
        Ok(HttpStatus::Http501NotImplemented)
    } else if code == 502 {
        Ok(HttpStatus::Http502BadGateway)
    } else if code == 503 {
        Ok(HttpStatus::Http503ServiceUnavailable)
    } else if code == 504 {
        Ok(HttpStatus::Http504GatewayTimeout)
    } else {
        Err(http_error(HttpStatus::Http400BadRequest, "unknown status code"))
    }
}

// ── Request builder ──────────────────────────────────────────────────────────
/// Build a raw HTTP/1.0 request string suitable for feeding into parse_request.
pub total fn test_request(
    method: String,
    path: String,
) -> String {
    method.concat(" ").concat(path).concat(" HTTP/1.0\r\n\r\n")
}

// ── Response parser ──────────────────────────────────────────────────────────
/// Parse a raw HTTP/1.x response string into a Response.
///
/// Inverse of serialize_response — enables round-trip testing.
pub partial fn parse_response(raw: String) -> Result[Response, HttpError] {
    let lines: List[String] = raw.split("\r\n");
    let status_line: String = match lines.get(0) {
        Some(s) => s,
        None => "",
    };
    if status_line == "" {
        Err(http_error(HttpStatus::Http400BadRequest, "empty response"))
    } else {
        let parts: List[String] = status_line.split(" ");
        if parts.len() < 3 {
            Err(http_error(HttpStatus::Http400BadRequest, "malformed status line"))
        } else {
            let code_str: String = match parts.get(1) {
                Some(s) => s,
                None => "",
            };
            match code_str.parse_int() {
                Err(_) => Err(http_error(HttpStatus::Http400BadRequest, "non-numeric status code")),
                Ok(code) => match status_from_code(code) {
                    Err(e) => Err(e),
                    Ok(status) => Ok(parse_rest(lines, status)),
                },
            }
        }
    }
}

/// Parse headers + body given the lines (after status line) and the status enum.
partial fn parse_rest(
    lines: List[String],
    status: HttpStatus,
) -> Response {
    let headers: ref Map[String, String] = Map::new();
    let i: ref Int = 1;
    let n: Int = lines.len();
    let body_start: ref Int = n;
    let in_body: ref Bool = false;
    while i < n && !in_body {
        let line: String = match lines.get(i) {
            Some(s) => s,
            None => "",
        };
        if line == "" {
            body_start = i + 1;
            in_body = true;
        } else {
            let kv: List[String] = line.split(": ");
            if kv.len() >= 2 {
                let k: String = match kv.get(0) {
                    Some(s) => s,
                    None => "",
                };
                let v: String = match kv.get(1) {
                    Some(s) => s,
                    None => "",
                };
                headers.insert(k, v)
            }
            i = i + 1;
        }
    }
    let body: ref String = match lines.get(body_start) {
        Some(s) => s,
        None => "",
    };
    for j in range(body_start + 1, n) {
        let line: String = match lines.get(j) {
            Some(s) => s,
            None => "",
        };
        body = body.concat("\r\n");
        body = body.concat(line);
    }
    Response { status: status, headers: headers, body: body }
}

// ── BDD-style assertion helpers ──────────────────────────────────────────────
/// True if the raw response's status code equals `expected`.
pub partial fn expect_status(
    raw: String,
    expected: HttpStatus,
) -> Bool {
    match parse_response(raw) {
        Ok(r) => status_code(r.status) == status_code(expected),
        Err(_) => false,
    }
}

/// True if the raw response's body contains `expected` as a substring.
pub partial fn expect_body_contains(
    raw: String,
    expected: String,
) -> Bool {
    match parse_response(raw) {
        Ok(r) => r.body.contains(expected),
        Err(_) => false,
    }
}

/// True if the raw response contains a header `key: value`.
pub partial fn expect_header(
    raw: String,
    key: String,
    value: String,
) -> Bool {
    match parse_response(raw) {
        Ok(r) => match r.headers.get(key) {
            Some(v) => v == value,
            None => false,
        },
        Err(_) => false,
    }
}
