test fn method_name_get()     -> Unit { assert_eq(method_name(Method::Get),     "GET") }
test fn method_name_post()    -> Unit { assert_eq(method_name(Method::Post),    "POST") }
test fn method_name_put()     -> Unit { assert_eq(method_name(Method::Put),     "PUT") }
