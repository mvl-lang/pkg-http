// ── created() response builder ────────────────────────────────────────────────

test fn created_response_has_201_status() -> Unit {
    let r: Response = created("body");
    assert_eq(status_code(r.status), 201)
}

test fn created_response_preserves_body() -> Unit {
    let r: Response = created("the body");
    assert_eq(r.body, "the body")
}

// ── is_success / is_error: edge cases ────────────────────────────────────────

test fn accepted_is_success()        -> Unit { assert_eq(is_success(Status::Http202Accepted), true) }
test fn no_content_is_success()      -> Unit { assert_eq(is_success(Status::Http204NoContent), true) }
test fn redirect_is_not_success()    -> Unit { assert_eq(is_success(Status::Http301MovedPermanently), false) }
test fn unauthorized_is_error()      -> Unit { assert_eq(is_error(Status::Http401Unauthorized), true) }
test fn not_found_is_error()         -> Unit { assert_eq(is_error(Status::Http404NotFound), true) }
test fn redirect_is_not_error()      -> Unit { assert_eq(is_error(Status::Http301MovedPermanently), false) }

