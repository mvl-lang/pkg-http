test fn code_202() -> Unit { assert_eq(status_code(Status::Http202Accepted), 202) }
test fn code_302() -> Unit { assert_eq(status_code(Status::Http302Found), 302) }
test fn code_304() -> Unit { assert_eq(status_code(Status::Http304NotModified), 304) }
test fn code_410() -> Unit { assert_eq(status_code(Status::Http410Gone), 410) }
test fn code_501() -> Unit { assert_eq(status_code(Status::Http501NotImplemented), 501) }

