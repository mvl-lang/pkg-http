test fn reason_302() -> Unit { assert_eq(status_reason(Status::Http302Found), "Found") }
test fn reason_304() -> Unit { assert_eq(status_reason(Status::Http304NotModified), "Not Modified") }
test fn reason_400() -> Unit { assert_eq(status_reason(Status::Http400BadRequest), "Bad Request") }
test fn reason_401() -> Unit { assert_eq(status_reason(Status::Http401Unauthorized), "Unauthorized") }
test fn reason_403() -> Unit { assert_eq(status_reason(Status::Http403Forbidden), "Forbidden") }
test fn reason_405() -> Unit { assert_eq(status_reason(Status::Http405MethodNotAllowed), "Method Not Allowed") }
test fn reason_409() -> Unit { assert_eq(status_reason(Status::Http409Conflict), "Conflict") }
test fn reason_410() -> Unit { assert_eq(status_reason(Status::Http410Gone), "Gone") }
test fn reason_422() -> Unit { assert_eq(status_reason(Status::Http422UnprocessableEntity), "Unprocessable Entity") }
test fn reason_429() -> Unit { assert_eq(status_reason(Status::Http429TooManyRequests), "Too Many Requests") }
test fn reason_501() -> Unit { assert_eq(status_reason(Status::Http501NotImplemented), "Not Implemented") }
test fn reason_502() -> Unit { assert_eq(status_reason(Status::Http502BadGateway), "Bad Gateway") }
test fn reason_503() -> Unit { assert_eq(status_reason(Status::Http503ServiceUnavailable), "Service Unavailable") }
test fn reason_504() -> Unit { assert_eq(status_reason(Status::Http504GatewayTimeout), "Gateway Timeout") }

